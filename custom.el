;;; -*- lexical-binding: t -*-

(custom-set-variables
 ;; custom-set-variables was added by Custom.
 ;; If you edit it by hand, you could mess it up, so be careful.
 ;; Your init file should contain only one such instance.
 ;; If there is more than one, they won't work right.
 '(dslide-breadcrumb-separator " > ")
 '(dslide-slide-in-effect nil)
 '(lua-default-application "/opt/homebrew/bin/lua")
 '(lua-indent-level 4)
 '(ns-alternate-modifier 'meta)
 '(ns-command-modifier 'super)
 '(package-selected-packages
   '(## auctex cmake-mode company-quickhelp dap-mode dired-git-info
	doom-modeline hide-mode-line javap-mode kotlin-mode llama
	logos lsp-ui lua-mode luarocks minesweeper olivetti org-roam
	org-tree-slide python-mode simpc-mode smex telephone-line
	transpose-frame treesit treesit-fold visual-fill-column xkcd)))
(custom-set-faces
 ;; custom-set-faces was added by Custom.
 ;; If you edit it by hand, you could mess it up, so be careful.
 ;; Your init file should contain only one such instance.
 ;; If there is more than one, they won't work right.
 '(default ((t (:inherit nil :extend nil :stipple nil :background "black" :foreground "gray80" :inverse-video nil :box nil :strike-through nil :overline nil :underline nil :slant normal :weight regular :height 150 :width normal :foundry "nil" :family "JetBrains Mono NL"))))
 '(error ((t (:foreground "firebrick1"))))
 '(fixed-pitch ((t (:family "Jetbrains Mono NL"))))
 '(line-number-current-line ((t (:inherit line-number :foreground "DeepSkyBlue1"))))
 '(mode-line ((t (:background "gray10" :foreground "gray100" :box nil :height 150))))
 '(mode-line-buffer-id ((t (:foreground "deepskyblue1" :weight bold))))
 '(mode-line-highlight ((t (:box nil))))
 '(mode-line-inactive ((t (:background "black" :foreground "gray35" :box nil))))
 '(shadow ((t (:foreground "gray40")))))
